{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "portless run --force --name acme.api tsdown --watch --on-success \"node dist/index.mjs\"",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@hono/zod-validator": "^0.7.6",
    "@repo/auth": "workspace:*",
    "@repo/db": "workspace:*",
    "dotenv": "^17.4.0",
    "hono": "^4.12.10",
    "hono-rate-limiter": "^0.5.3",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/config-vitest": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@rollup/plugin-alias": "^6.0.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.5.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
