{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "tsdown --watch --on-success \"node dist/index.js\"",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-openapi": "^1.2.2",
    "@hono/zod-validator": "^0.7.6",
    "@repo/auth": "workspace:*",
    "@repo/db": "workspace:*",
    "better-auth": "^1.5.5",
    "dotenv": "^17.3.1",
    "hono": "^4.12.8",
    "hono-rate-limiter": "^0.5.3",
    "pino-http": "^11.0.0",
    "resend": "^6.9.4",
    "undici": "^7.22.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/config-vitest": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@rollup/plugin-alias": "^6.0.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.3.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
