{
  "name": "workshop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "dev:live": "storybook dev -p 3000 --ci --host staging.ui.namespace.ninja",
