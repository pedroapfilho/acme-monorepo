    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-themes": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@total-typescript/ts-reset": "^0.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "serve": "^14.2.6",
    "storybook": "^10.3.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
