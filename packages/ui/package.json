{
  "name": "@repo/ui",
  "version": "0.0.0",
  "license": "MIT",
  "style": "./dist/index.css",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./dist/index.css"
  },
  "scripts": {
    "build": "mkdir -p dist && pnpm run build:styles && pnpm run build:components",
    "build:styles": "tailwindcss -i ./src/styles/globals.css -o ./dist/index.css",
    "build:components": "tsdown",
    "typecheck": "tsc --noEmit",
    "dev:styles": "tailwindcss -i ./src/styles/globals.css -o ./dist/index.css --watch",
    "dev:components": "tsdown --watch",
    "lint": "oxlint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tanstack/react-form": "^1.28.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "react-day-picker": "^9.14.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/config-vitest": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/cli": "^4.2.2",
    "@types/react": "^19.2.0",
    "tailwindcss": "^4.2.2",
    "tsdown": "^0.21.7",
    "tw-animate-css": "^1.4.0",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
