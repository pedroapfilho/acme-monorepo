{
  "name": "acme",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "turbo run start",
    "dev": "openlogs turbo run dev",
    "lint": "oxlint .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:seed": "turbo run db:seed",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "fallow": "fallow",
    "fallow:dead": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:health": "fallow health --score",
    "fallow:audit": "fallow audit --base main",
    "prepare": "husky",
    "ci:local": "agent-ci run --quiet --all --pause-on-failure",
    "ci:local:fast": "agent-ci run --quiet --pause-on-failure -w .github/workflows/test.yml && agent-ci run --quiet --pause-on-failure -w .github/workflows/lint.yml && agent-ci run --quiet --pause-on-failure -w .github/workflows/format.yml && agent-ci run --quiet --pause-on-failure -w .github/workflows/fallow.yml",
    "ci:local:e2e": "agent-ci run --quiet --pause-on-failure -w .github/workflows/e2e.yml"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@redwoodjs/agent-ci": "^0.15.0",
    "fallow": "^2.66.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-config-awesomeness": "^3.0.2",
    "turbo": "^2.9.9"
  },
  "lint-staged": {
    "!(*.d).{ts,tsx,mts,cts,js,jsx,mjs,cjs}": [
      "oxlint"
    ],
    "*.{ts,tsx,mts,cts,js,jsx,mjs,cjs,json,md}": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.0.8"
}
